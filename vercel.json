{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "taubinha.sqlite",
          "node_modules/sql.js/dist/sql-wasm.wasm"
        ]
      }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "index.js" }]
}
